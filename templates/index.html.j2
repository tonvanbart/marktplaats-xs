<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>marktplaats-xs</title>

  <link rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="">
  <link rel="stylesheet"
        href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
  <link rel="stylesheet"
        href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">

  <style>
    html, body { margin: 0; padding: 0; height: 100%; font-family: system-ui, sans-serif; }
    #map { position: absolute; top: 0; bottom: 32px; left: 0; right: 0; }
    #footer {
      position: absolute; bottom: 0; left: 0; right: 0; height: 32px;
      display: flex; align-items: center; padding: 0 12px;
      font-size: 12px; color: #555; background: #f5f5f5;
      border-top: 1px solid #ddd;
    }
    #errors {
      position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
      z-index: 1000; max-width: 80%;
      background: #fff3cd; color: #664d03; border: 1px solid #ffecb5;
      padding: 8px 12px; border-radius: 4px; font-size: 13px;
    }
    .popup-thumb { width: 160px; height: auto; display: block; margin-bottom: 6px; }
    .popup-title { font-weight: 600; margin-bottom: 2px; }
    .popup-meta  { font-size: 12px; color: #555; margin-bottom: 4px; }
    .popup-reserved {
      display: inline-block; background: #d9534f; color: #fff;
      padding: 1px 6px; border-radius: 3px; font-size: 11px; margin-left: 4px;
    }
    .leaflet-popup-content { margin: 10px 12px; }
  </style>
</head>
<body>

<div id="map"></div>

{% if has_errors %}
<div id="errors">
  Some queries failed to fetch in this build:
  {% for r in results if r.error %}
    <strong>{{ r.name }}</strong>{% if not loop.last %}, {% endif %}
  {% endfor %}
</div>
{% endif %}

<div id="footer">Last updated: {{ generated_at }}</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>

<script>
  const queries = {{ results | tojson }};

  const map = L.map('map').setView([52.2, 5.3], 8);

  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>'
  }).addTo(map);

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function popupHtml(listing) {
    const parts = [];
    if (listing.thumbUrl) {
      parts.push('<img class="popup-thumb" src="' + escapeHtml(listing.thumbUrl) + '" alt="">');
    }
    const reservedBadge = listing.reserved
      ? ' <span class="popup-reserved">Gereserveerd</span>' : '';
    parts.push('<div class="popup-title">' + escapeHtml(listing.title) + reservedBadge + '</div>');
    parts.push(
      '<div class="popup-meta">' +
      escapeHtml(listing.priceDisplay) + ' &middot; ' +
      escapeHtml(listing.city) + ' &middot; ' +
      escapeHtml(listing.date) +
      '</div>'
    );
    parts.push('<a href="' + escapeHtml(listing.url) + '" target="_blank" rel="noopener">Bekijk op Marktplaats</a>');
    return parts.join('');
  }

  const overlays = {};
  queries.forEach(function (q) {
    const group = L.markerClusterGroup();
    (q.listings || []).forEach(function (l) {
      const marker = L.marker([l.lat, l.lon]);
      marker.bindPopup(popupHtml(l), { maxWidth: 220 });
      marker.bindTooltip(l.title, { direction: 'top' });
      group.addLayer(marker);
    });
    group.addTo(map);
    overlays[q.name + ' (' + (q.listings || []).length + ')'] = group;
  });

  if (Object.keys(overlays).length > 0) {
    L.control.layers(null, overlays, { collapsed: false }).addTo(map);
  }
</script>

</body>
</html>
